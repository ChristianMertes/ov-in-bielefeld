# TMDb API key (free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your personal chat ID (find via @userinfobot or /start command)
TELEGRAM_CHAT_ID=your_chat_id_here

# Web app URL (for links in Telegram messages)
WEBAPP_URL=https://your-domain.example.com

# Database path (default: kino_ov.db in working directory)
KINO_DB_PATH=./kino_ov.db

# Web server port
PORT=8000
